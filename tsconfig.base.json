{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@korean-erp/shared": ["packages/shared/src"],
      "@korean-erp/contracts": ["packages/contracts/src"],
      "@korean-erp/domain": ["packages/domain/src"],
      "@korean-erp/sdk": ["packages/sdk/src"],
      "@korean-erp/ui": ["packages/ui/src"]
    }
  }
}
