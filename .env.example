# Shared monorepo defaults
NODE_ENV=development
TZ=Asia/Seoul
SEED_DEFAULT_PASSWORD=ChangeMe123!

# API
API_PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/erp
REDIS_URL=redis://localhost:6379
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=erp-files
MINIO_USE_SSL=false
DOCS_SERVICE_BASE_URL=http://localhost:4300
INTEGRATION_INGEST_API_KEY=dev-integration-key

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
WEB_PORT=3000

# Worker
WORKER_PORT=4100
ATTENDANCE_NORMALIZE_BATCH_SIZE=500

# Gateway/Docs service
CONNECTOR_GATEWAY_PORT=4200
DOCS_SERVICE_PORT=4300
EDGE_AGENT_SHARED_KEY=dev-edge-agent-key
DEFAULT_COMPANY_CODE=ACME_KR

# Edge agent (optional local run)
EDGE_AGENT_CSV_PATH=agents/edge-agent/samples/attendance
EDGE_AGENT_GATEWAY_URL=http://localhost:4200/ingestion/events
EDGE_AGENT_API_KEY=dev-edge-agent-key
EDGE_AGENT_POLL_SECONDS=30
EDGE_AGENT_IDENTITY_MAP_PATH=agents/edge-agent/samples/attendance/identity-map.json
EDGE_AGENT_BUFFER_PATH=agents/edge-agent/data/failed-events.jsonl
EDGE_AGENT_COMPANY_CODE=ACME_KR
EDGE_AGENT_PROVIDER=GENERIC
